{{define "drclusters" -}}
<dl class="validation">
    <dt>Clusters</dt>
    <dd>
        <span class="value">{{len .Value}}</span>
        <span class="state">{{icon .State}}</span>
        {{- if .Description}}
            <p class="description">{{.Description}}</p>
        {{- end}}
    </dd>
</dl>
{{- range .Value}}
<section>
    <h5>{{.Name}}</h5>
    <dl class="metadata">
        <dt>Phase</dt>
        <dd>{{.Phase}}</dd>
    </dl>
    <section>
        <details{{if shouldOpen .Conditions}} open{{end}}>
            <summary><h6>Conditions</h6><span class="state">{{icon .Conditions.AggregateState}}</span></summary>
            {{template "conditions" .Conditions}}
        </details>
    </section>
</section>
{{- end}}
{{- end}}
